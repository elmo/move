<div class="hidden border-r border-gray-200 dark:border-gray-700 top-0 left-0 right-auto w-full h-full z-40
            sm:w-3/5
            md:w-2/5
            lg:block lg:h-full lg:left-0 lg:right-auto lg:w-1/4
            xl:w-1/5
            2xl:w-1/6">
  <div class="relative flex items-center justify-between space-x-2 mb-12 lg:mb-16">
    <%= render "shared/components/logo", 
      link_path: '/login' , 
      image: 'logo.jpg', 
      height: '30px',
      logo_format: nil  %>
  </div>

  <%= render "layouts/global/nav",
              container_classes: "space-y-2 px-2
                                  lg:fixed lg:overflow-y-auto lg:h-screen lg:w-1/4
                                  xl:w-1/5
                                  2xl:w-1/6",
              link_container_classes: "group/nav-link rounded",
              active_link_container_classes: "bg-gray-50",
              inactive_link_container_classes: "hover:bg-gray-50",
              link_padding: "py-3 pl-2 pr-4",
              link_classes: "rounded",
              inactive_icon_container_classes: "text-gray-600",
              active_icon_container_classes: "text-black",
              inactive_label_classes: "text-primary font-medium group-hover/nav-link:text-black",
              active_label_classes: "text-black font-medium" %>
</div>

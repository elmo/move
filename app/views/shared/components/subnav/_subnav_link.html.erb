<%
  link_path = local_assigns[:link_path]
  link_text = local_assigns[:link_text]
  link_target = local_assigns[:link_target]
  icon_name = local_assigns[:icon_name]
  active = local_assigns[:active]
%>

<%= link_to link_path,
            class: "#{'active-subnav-item' if active}
                    group flex items-start space-x-2 py-2 rounded
                    #{icon_name ? 'pl-2 pr-4' : 'px-4' }
                    hover:bg-gray-100 
                    #{'bg-gray-100' if active}",
            target: link_target do %>
  <% if icon_name %>
    <div class="w-8 h-[1.7rem] flex items-center justify-center text-center text-gray-100 group-hover:text-primary-100 
                <%= 'text-black-100' if active %>">
      <%= icon(icon_name) %>
    </div>
  <% end %>
  <div class="subnav-link-text flex-1 min-h-[1.7rem] font-medium <%= 'text-black' if active %>">
    <%= link_text %>
  </div>
<% end %>
